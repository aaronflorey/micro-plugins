{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": true,
  "separate-pull-requests": true,
  "packages": {
    "plugins/format": {
      "component": "format",
      "package-name": "format",
      "release-type": "simple",
      "extra-files": [
        "version.txt",
        "format.lua",
        {
          "type": "json",
          "path": "repo.json",
          "jsonpath": "$[0].Versions[0].Version"
        },
        {
          "type": "json",
          "path": "/repo.json",
          "jsonpath": "$[0].Versions[0].Version"
        }
      ]
    },
    "plugins/configdel": {
      "component": "configdel",
      "package-name": "configdel",
      "release-type": "simple",
      "extra-files": [
        "version.txt",
        "configdel.lua",
        {
          "type": "json",
          "path": "repo.json",
          "jsonpath": "$[0].Versions[0].Version"
        }
      ]
    },
    "plugins/jsonschema": {
      "component": "jsonschema",
      "package-name": "jsonschema",
      "release-type": "simple",
      "extra-files": [
        "version.txt",
        "jsonschema.lua",
        {
          "type": "json",
          "path": "repo.json",
          "jsonpath": "$[0].Versions[0].Version"
        }
      ]
    }
  }
}
