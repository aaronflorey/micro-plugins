// Per-plugin repo.json files are in plugins/<name>/repo.json
// For use as a plugin channel, point micro to channel.json instead.
// This file is kept for compatibility - only "format" is resolved from here
// due to a micro limitation (PluginRepository.Fetch returns plugins[0] only).
[{
  "Name": "format",
  "Description": "Format the current buffer using an installed formatter for its file type",
  "Website": "local",
  "Tags": ["formatting"],
  "Versions": [
    {
      "Version": "0.1.0",
      "Require": {
        "micro": ">=2.0.0"
      }
    }
  ]
}]
